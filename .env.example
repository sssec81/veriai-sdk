# Local real-inference / mock-attestation demo
VERIAI_RUNTIME=llama_cpp
VERIAI_MODEL_PATH=/absolute/path/to/model.gguf
LLAMA_CLI_PATH=/opt/homebrew/bin/llama-cli

# Optional: retain verifier sequence state for this process
STATEFUL_VERIFICATION=false

# Verifier service / real-hardware configuration
# TRUSTED_ROOT_CERT_PATH=/absolute/path/to/trusted-root.pem
# EXPECTED_PCR0=<96 hex characters>
# TRUSTED_ROOT_CERT_PEM="-----BEGIN CERTIFICATE-----..."
# PORT=8080
# RUST_LOG=info
